/obj/structure/rock/dark/large/two{
	icon = 'icons/obj/structures/vietzhuo8landmarks.dmi';
	icon_state = "eastvietzhuo_statue";
	name = "vietzhuo-8 east statue";
	desc = "This statue is dedicated to a dwarven man viewed as a hero by much of the East Vietzhuan people. Shao Xi Hwang was the leader of the East Vietzhuan Liberation Movement, advocating for communist-nationalism and traditionalist values. During the Vietzhuan-Revolt, he was able to amass thousands of supporters and was even able to gain support from the Sons of Mars after engaging in successful diplomatic talks. To his detractors he lives in infamy as a man who commanded marauders and terrorists alike to carry out raids on West-Vietzhuan settlements. Hwang dropped off the face of the Vietzhuan-8 sector, his whereabouts remain unknown but he is actively remembered by villagers of East Vietzhuo settlements. During the day some of his speeches are transmitted throughout some East Vietzhuan villages."
	},
